# Core Platform Config
PROJECT_NAME="Repository Intelligence Platform"
VERSION=1.0.0
DEBUG=true

# API Settings
API_V1_STR=/api/v1
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:8000"

# Groq API Configuration
GROQ_API_KEY="your-groq-api-key"
DEFAULT_LLM_MODEL=llama-3.3-70b-specdec

# Fallback Settings
OPENAI_API_KEY="your-optional-openai-key-for-embeddings"
LONG_TERM_MEMORY_EMBEDDER_MODEL=text-embedding-3-small

# Database Settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=repo_intel_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
api_profiles
PROFILING_THRESHOLD_SECONDS=2.0

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
